        print("  Cancelled.")
        return

    result = post_tweet(tweet_text)
    if result:
        state["tweets_posted"] = state.get("tweets_posted", 0) + 1
        history = state.get("tweet_history", [])
        history.append(tweet_text)
        state["tweet_history"] = history[-20:]
