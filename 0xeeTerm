        print("  [ERROR] Brain failed to generate verdict tweet — check logs.")
        return
    tweet_text = (
        f"WALLET VERDICT\n\n"
        f"{body}\n\n"
        f"Wallet Verdict — 0.01 SOL — ai.0xee.li\n"
